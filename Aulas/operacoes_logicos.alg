algoritmo "Operações Logicos"

var
    expressao1: logico
    expressao2: logico

inicio
    expressao1 <- 5 < 10
    expressao2 <- 20 < 10
    escreval("Expressão 1: ", expressao1)
    escreval("Expressão 2: ", expressao2)

    escreval("V e F = ", expressao1 e expressao2)
    escreval("V ou F = ", expressao1 ou expressao2)

 
